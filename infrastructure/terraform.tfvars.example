# Copy to terraform.tfvars and fill in values. Do not commit terraform.tfvars.
# See .cursor/rules/terraform-standards.mdc: no secrets in .tf; use tfvars (gitignored).

project_name = "cdss"
environment  = "dev"
aws_region   = "us-east-1"

# Required: set via TF_VAR_db_username / TF_VAR_db_password or fill below (sensitive)
# db_username = "admin"
# db_password = "CHANGE_ME"

# Optional overrides
# api_require_cognito = true
# enable_lambda_vpc   = false
# bedrock_model_id   = "us.anthropic.claude-3-5-sonnet-v2:0"

# AgentCore (docs/agentcore-implementation-plan.md). Set after deploying agent from agentcore/agent/
# use_agentcore     = false
# agent_runtime_arn = ""
