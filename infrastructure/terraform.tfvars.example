# Terraform variable template. Copy to terraform.tfvars and set real values.
# terraform.tfvars is gitignored; do not commit it.

# Required – no defaults (secrets)
db_username = "cdssadmin"
db_password = "REPLACE_WITH_AURORA_MASTER_PASSWORD"

# Optional – Lambda in VPC so it can reach Aurora (default true)
# enable_lambda_vpc = false

# Optional – require Cognito on API (default true; set false for local/dev without auth)
# api_require_cognito = false
