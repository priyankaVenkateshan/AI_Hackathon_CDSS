# CDSS Doctor Dashboard – environment variables
# Copy to .env and set values. All client-side vars must be prefixed with VITE_.

# Base URL of the CDSS REST API (no trailing slash). When empty or unset, app uses mock data.
# Local API: http://localhost:8080
# Example (AWS): https://xxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod
VITE_API_URL=http://localhost:8080

# Use mock data instead of live API. Set to true or 1 for mock; false or leave unset when using live API.
VITE_USE_MOCK=false

# Optional: if your API Gateway requires an API key, set it (sent as x-api-key header).
# VITE_API_KEY=
# Example: wss://xxxxxxxx.execute-api.ap-south-1.amazonaws.com/prod
VITE_WS_URL=

# Optional: Amazon Cognito (when set, login uses Cognito and JWT is sent to API).
# VITE_COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
# VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_COGNITO_REGION=ap-south-1
