# CDSS Database Configuration
# Copy to .env and fill in your values. Do not commit .env (it is gitignored).

# ---------------------------------------------------------------------------
# Option 1: Aurora via SSM tunnel (production)
# Start the tunnel first: .\scripts\start_ssm_tunnel.ps1
# Then set DATABASE_URL with port 5433 (tunnel port) and Aurora master password.
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://cdssadmin:YOUR_PASSWORD@localhost:5433/cdssdb

# ---------------------------------------------------------------------------
# Option 2: AWS Aurora IAM auth (Lambda; no password in URL; uses Secrets Manager)
# Set these instead of DATABASE_URL when running in AWS.
# ---------------------------------------------------------------------------
# RDS_CONFIG_SECRET_NAME=cdss-dev/rds-config
# AWS_REGION=ap-south-1

# ---------------------------------------------------------------------------
# Optional: echo SQL to console for debugging
# ---------------------------------------------------------------------------
# SQL_ECHO=1

# ---------------------------------------------------------------------------
# MCP / ABDM (Phase 2 – Real Integrations)
# Set in .env for local dev, or put in Secrets Manager app-config in production.
# Leave empty to use stub responses.
# ---------------------------------------------------------------------------
# Hospital HIS MCP base URL (OT status, beds, equipment)
# MCP_HOSPITAL_ENDPOINT=https://your-hospital-mcp.example.com
# ABDM Gateway or sandbox base URL (patient record lookup)
# MCP_ABDM_ENDPOINT=
# ABDM_SANDBOX_URL=https://abdm-sandbox.example.com

# ---------------------------------------------------------------------------
# Bedrock (optional; defaults to Nova Lite when not set)
# ---------------------------------------------------------------------------
# BEDROCK_CONFIG_SECRET_NAME=cdss-dev/bedrock-config
# Or override model for local runs:
# BEDROCK_MODEL_ID=apac.amazon.nova-lite-v1:0
