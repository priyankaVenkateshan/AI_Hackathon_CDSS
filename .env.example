# CDSS Database Configuration
# Copy to .env and fill in your values. Do not commit .env (it is gitignored).

# ---------------------------------------------------------------------------
# Option 1: Local PostgreSQL (recommended for dev)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://username:password@localhost:5432/cdss_db

# ---------------------------------------------------------------------------
# Option 2: AWS RDS / Aurora (direct URL with password)
# ---------------------------------------------------------------------------
# DATABASE_URL=postgresql://admin:yourpassword@cdss-db.xxxxxx.ap-south-1.rds.amazonaws.com:5432/cdssdb

# ---------------------------------------------------------------------------
# Option 3: AWS Aurora IAM auth (no password in URL; uses Secrets Manager)
# Set these instead of DATABASE_URL. Terraform creates the secret.
# ---------------------------------------------------------------------------
# RDS_CONFIG_SECRET_NAME=cdss-dev/rds-config
# AWS_REGION=ap-south-1
# Optional when using SSM port forward to private RDS:
# TUNNEL_LOCAL_PORT=10021

# ---------------------------------------------------------------------------
# Optional: echo SQL to console for debugging
# ---------------------------------------------------------------------------
# SQL_ECHO=1
